@model OrderGenerator.Web.Models.OrderViewModel

@{
    ViewData["Title"] = "Order Generator";
}

<h2>Order Generator</h2>

<form asp-action="Index" method="post">
    <div style="margin-bottom: 12px;">
        <label asp-for="Symbol"></label>
        <select asp-for="Symbol">
            <option value="">Select</option>
            <option value="PETR4">PETR4</option>
            <option value="VALE3">VALE3</option>
            <option value="VIIA4">VIIA4</option>
        </select>
        <span asp-validation-for="Symbol" style="color:red;"></span>
    </div>

    <div style="margin-bottom: 12px;">
        <label asp-for="OperationType"></label>
        <select asp-for="OperationType">
            <option value="">Select</option>
            <option value="Buy">Buy</option>
            <option value="Sell">Sell</option>
        </select>
        <span asp-validation-for="OperationType" style="color:red;"></span>
    </div>

    <div style="margin-bottom: 12px;">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" />
        <span asp-validation-for="Quantity" style="color:red;"></span>
    </div>

    <div style="margin-bottom: 12px;">
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" />
        <span asp-validation-for="Price" style="color:red;"></span>
    </div>

    <button type="submit">Send Order</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
{
    <div style="margin-top:20px; padding:10px; border:1px solid #ccc;">
        @Model.ResultMessage
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}